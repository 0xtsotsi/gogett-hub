[run]
source = app/modules/agent_surfaces
omit =
    */tests/*
parallel = true
relative_files = true
sigterm = true
concurrency =
    multiprocessing
    thread

[report]
show_missing = true
skip_covered = false
sort = Cover

[html]
directory = coverage-agent-surfaces/html

[xml]
output = coverage-agent-surfaces/coverage.xml

[json]
output = coverage-agent-surfaces/coverage.json
