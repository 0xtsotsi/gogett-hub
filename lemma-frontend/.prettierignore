# Prettier ignore — additive on top of .gitignore (Prettier reads both).
# Keeps generated artifacts, framework caches, and dependency trees out of
# `npm run format:check` so drift in those paths doesn't fail the check.

# Dependencies
node_modules
.pnp.*

# Next.js build/cache outputs
.next
out

# Production / build artifacts
build
dist
*.tsbuildinfo

# Next.js type shim (auto-generated by `next dev`/`next build`)
next-env.d.ts

# Runtime config (generated by scripts/gen-runtime-config.mjs and by
# docker-entrypoint.sh at container start)
public/runtime-config.js

# Coverage outputs
coverage
*.lcov

# Package manager caches / logs
.npm-cache
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
